APP_BASE_URL=http://localhost:8001
# Public URL of the web app (use your Render URL in production, e.g. https://myapp.onrender.com)
FRONTEND_BASE_URL=http://localhost:5173
PASSWORD_RESET_PATH=/reset-password

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=host@email.com
SMTP_PASSWORD=smtppassword
SMTP_FROM=no-reply@surrealapp.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Verification code expiry (in seconds)
EMAIL_VERIFICATION_TTL_SECONDS=3600

# Surreal instance settings
SURREAL_URL=SURREAL-URL
SURREAL_NAMESPACE=main
SURREAL_DB=main
SURREAL_USERNAME=root
SURREAL_PASSWORD=root

# Auth / JWT
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=1

# Password reset
PASSWORD_RESET_TTL_SECONDS=1800